<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>
    <comment>Base application configuration for srv.cgm.importer.</comment>
    <entry key="spring.application.name">srv.cgm.importer</entry>
    <entry key="spring.servlet.multipart.max-file-size">500MB</entry>
    <entry key="spring.servlet.multipart.max-request-size">500MB</entry>
    <entry key="spring.data.elasticsearch.repositories.enabled">false</entry>
    <entry key="management.tracing.sampling.probability">1.0</entry>
    <entry key="springdoc.api-docs.path">/openapi</entry>
    <entry key="springdoc.swagger-ui.path">/swagger-ui.html</entry>
    <entry key="logging.level.eu.tscnet">INFO</entry>
</properties>
